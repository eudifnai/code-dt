{
  "name": "codedt",
  "version": "0.2.0",
  "private": true,
  "description": "CodeDT is a DeepSeek-first local AI coding workspace.",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && electron .\"",
    "dev:web": "vite",
    "build": "tsc -b && vite build && tsc -p electron/tsconfig.json",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "lint": "eslint ."
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@vitejs/plugin-react": "^4.7.0",
    "lucide-react": "^0.468.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.3.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.0.0",
    "electron": "^35.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "typescript": "~5.8.0",
    "typescript-eslint": "^8.0.0",
    "wait-on": "^8.0.0"
  }
}
